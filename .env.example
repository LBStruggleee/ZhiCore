APP_NAME="Enterprise Knowledge Base Agent"
DATA_DIR=data
UPLOADS_DIR=data/uploads
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=enterprise_kb

# openai or huggingface
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Used when EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
DEFAULT_TOP_K=5
