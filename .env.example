APP_NAME="Enterprise Knowledge Base Agent"
DATA_DIR=data
UPLOADS_DIR=data/uploads
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=enterprise_kb

# dashscope or huggingface
EMBEDDING_PROVIDER=dashscope
DASHSCOPE_API_KEY=
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_CHAT_MODEL=qwen-plus

# Used when EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
DEFAULT_TOP_K=5
